<Project>
  <ItemGroup>
    <Analyzer Include="$(MSBuildThisFileDirectory)..\analyzers\dotnet\cs\Everlong.Settings.Generators.dll"
             Condition="'$(Language)' == 'C#' and Exists('$(MSBuildThisFileDirectory)..\analyzers\dotnet\cs\Everlong.Settings.Generators.dll')" />
    <Analyzer Include="$(MSBuildThisFileDirectory)..\analyzers\dotnet\cs\Everlong.Settings.CodeFixers.dll"
             Condition="'$(Language)' == 'C#' and Exists('$(MSBuildThisFileDirectory)..\analyzers\dotnet\cs\Everlong.Settings.CodeFixers.dll')" />
  </ItemGroup>
</Project>
